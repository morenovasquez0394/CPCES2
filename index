<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CP CES - Control Logístico de Patio</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Librería para escanear QR / Código de Barras -->
    <script src="https://unpkg.com/html5-qrcode"></script>
    <!-- Enlace a los estilos -->
    <link rel="stylesheet" href="style.css">
</head>
<body class="bg-[#020617] text-slate-200 min-h-screen">

    <!-- LOGIN -->
    <div id="loginScreen" class="h-screen flex items-center justify-center p-4">
        <div class="glass p-12 rounded-[2.5rem] shadow-2xl text-center w-full max-w-sm border-t border-white/10">
            <h2 class="text-5xl font-black mb-10 bg-gradient-to-br from-blue-400 via-indigo-400 to-emerald-400 bg-clip-text text-transparent italic tracking-tighter">CP CES</h2>

            <div id="loginForm" class="flex flex-col gap-4">
                <input id="loginUser" class="p-4 bg-slate-900/80 rounded-2xl outline-none border border-slate-700 focus:border-blue-500 transition-all text-center font-bold" placeholder="Usuario / Ficha" onkeydown="if(event.key==='Enter') document.getElementById('loginPass').focus()">
                <input id="loginPass" type="password" class="p-4 bg-slate-900/80 rounded-2xl outline-none border border-slate-700 focus:border-blue-500 transition-all text-center font-bold text-xs" placeholder="Clave de acceso" onkeydown="if(event.key==='Enter') intentarLogin()">
                <button onclick="intentarLogin()" class="bg-blue-600 hover:bg-blue-500 p-4 rounded-2xl font-black shadow-xl shadow-blue-900/40 transition-all active:scale-95 uppercase tracking-widest mt-2">Ingresar</button>
                <p id="loginError" class="text-red-500 text-[10px] mt-2 font-bold uppercase"></p>
            </div>

            <div id="changePassForm" class="hidden flex flex-col gap-4 text-left">
                <p class="text-yellow-500 text-xs mb-2 font-bold text-center uppercase tracking-widest">Crea tu Contraseña</p>
                <input id="newPass1" type="password" class="p-4 bg-slate-900 rounded-2xl border border-yellow-600/30 outline-none w-full" placeholder="Nueva Clave" onkeydown="if(event.key==='Enter') document.getElementById('newPass2').focus()">
                <input id="newPass2" type="password" class="p-4 bg-slate-900 rounded-2xl border border-yellow-600/30 outline-none w-full" placeholder="Confirmar Clave" onkeydown="if(event.key==='Enter') guardarNuevaPass()">
                <button onclick="guardarNuevaPass()" class="bg-yellow-600 p-4 rounded-2xl font-black text-slate-950 uppercase tracking-widest">Guardar y Entrar</button>
            </div>
        </div>
    </div>

    <!-- MENU PRINCIPAL -->
    <div id="menuPrincipal" class="hidden h-screen flex flex-col items-center justify-center p-4">
        <div class="text-center mb-16">
            <h1 class="text-[10px] tracking-[0.6em] text-blue-500 font-black uppercase mb-4">Sistema de Gestión de Terminal</h1>
            <p id="welcomeMsg" class="text-slate-400 italic text-sm font-light opacity-80"></p>
        </div>
        <div id="botonesAcceso" class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <button id="btn-GARITA" onclick="abrirModulo('garita')" class="hidden glass hover:bg-emerald-600/10 p-10 w-72 rounded-[2rem] transition-all border-emerald-500/20 group"><span class="block text-5xl mb-4 group-hover:scale-110 transition-transform">🚧</span><span class="font-black tracking-[0.3em] text-xs">GARITA</span></button>
            <button id="btn-PATIO" onclick="abrirModulo('patio')" class="hidden glass hover:bg-blue-600/10 p-10 w-72 rounded-[2rem] transition-all border-blue-500/20 group"><span class="block text-5xl mb-4 group-hover:scale-110 transition-transform">🚚</span><span class="font-black tracking-[0.3em] text-xs text-blue-400">PATIO</span></button>
            <button id="btn-DESPACHO" onclick="abrirModulo('despacho')" class="hidden glass hover:bg-purple-600/10 p-10 w-72 rounded-[2rem] transition-all border-purple-500/20 group"><span class="block text-5xl mb-4 group-hover:scale-110 transition-transform">📋</span><span class="font-black tracking-[0.3em] text-xs text-purple-400">DESPACHO</span></button>
            <button id="btn-CHOFER" onclick="abrirModulo('chofer')" class="hidden glass hover:bg-amber-600/10 p-10 w-72 rounded-[2rem] transition-all border-amber-500/20 group"><span class="block text-5xl mb-4 group-hover:scale-110 transition-transform">👤</span><span class="font-black tracking-[0.3em] text-xs text-amber-400">MI ESTADO</span></button>
            <button id="btn-ADMIN" onclick="abrirModulo('admin')" class="hidden glass hover:bg-slate-700/40 p-5 w-full rounded-2xl mt-4 sm:col-span-2 text-[9px] font-black tracking-[0.5em] border-slate-600/30 uppercase">Administración Central</button>
        </div>
        <button onclick="cerrarSesion()" class="mt-20 text-slate-700 hover:text-red-500 transition-colors text-[9px] tracking-[0.6em] font-black uppercase">Finalizar Sesión</button>
    </div>

    <!-- APP SHELL -->
    <div id="app" class="hidden min-h-screen flex flex-col">
        
        <!-- HEADER GLOBAL ESTATICO Y REDUCIDO -->
        <header class="sticky top-0 z-50 bg-[#020617]/95 backdrop-blur-xl border-b border-slate-800 px-4 lg:px-8 py-3 flex flex-col shadow-xl w-full transition-all">
            
            <!-- Fila Superior: Título, Sync y Botón Volver -->
            <div class="flex items-center justify-between w-full">
                <!-- Título y Sync (Izquierda) -->
                <div class="flex items-center gap-3 md:gap-4">
                    <button onclick="syncManual()" class="glass p-2.5 rounded-full text-sm md:text-lg hover:bg-blue-500/20 active:scale-95 transition-all shadow-lg border border-slate-700/50" title="Sincronizar Manualmente">🔄</button>
                    <div>
                        <h1 id="tituloModulo" class="text-lg md:text-2xl font-black italic tracking-tighter text-blue-500 uppercase leading-none mb-0.5">Módulo</h1>
                        <div class="flex items-center gap-2 md:gap-3">
                            <div id="reloj" class="text-[9px] md:text-[10px] font-mono text-slate-300 uppercase tracking-widest font-bold"></div>
                            <div id="fechaLarga" class="text-[9px] text-blue-400/60 uppercase tracking-widest font-black hidden md:block"></div>
                        </div>
                    </div>
                </div>

                <!-- Botón Volver (Derecha - Armónico y no invasivo) -->
                <button onclick="volverMenu()" class="glass bg-slate-900/40 hover:bg-red-900/20 border border-slate-800 hover:border-red-500/40 px-4 py-2 rounded-xl flex items-center gap-2 transition-all active:scale-95 shadow-md">
                    <span class="text-[9px] font-black tracking-[0.2em] text-slate-400 uppercase hidden sm:block">Centro de Control</span>
                    <span class="text-[9px] font-black tracking-[0.2em] text-slate-400 uppercase sm:hidden">Volver</span>
                    <span class="text-red-500/80 text-xs font-black">✕</span>
                </button>
            </div>

            <!-- Fila Inferior: Estadísticas (solo se muestra si hay datos) -->
            <div id="headerStats" class="w-full mt-3 overflow-hidden empty:hidden"></div>

        </header>

        <!-- CONTENEDOR DE MODULOS -->
        <div class="flex-1 w-full p-4 md:p-10 pt-6">

            <!-- GARITA -->
            <div id="garita" class="hidden max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:items-start">
                <div class="glass p-12 rounded-[3rem] flex flex-col justify-center items-center relative shadow-2xl border-t border-white/5 lg:sticky lg:top-[120px]">
                    <h2 class="text-3xl font-light mb-8 text-center tracking-tight">Registro de <b class="text-emerald-400 font-extrabold uppercase italic">Acceso</b></h2>
                    <div class="w-full space-y-6 relative z-10">
                        <div class="relative flex gap-4 w-full">
                            <input id="fichaEntrada" class="flex-1 min-w-0 w-full bg-slate-950/80 py-6 px-4 rounded-[2rem] border-2 border-slate-800 text-center text-4xl md:text-5xl font-black tracking-widest focus:border-emerald-500 outline-none transition-all input-glow text-emerald-400" placeholder="0000" onkeydown="if(event.key==='Enter') validarYRegistrar()">
                            <button onclick="iniciarScanner()" class="shrink-0 bg-slate-800 hover:bg-slate-700 px-6 text-3xl rounded-[2rem] border-2 border-slate-700 transition-all flex items-center justify-center" title="Escanear Código">📷</button>
                        </div>
                        <button onclick="validarYRegistrar()" class="w-full bg-emerald-600 hover:bg-emerald-500 p-8 rounded-2xl font-black text-2xl shadow-2xl shadow-emerald-900/40 transition-all active:scale-95 uppercase tracking-[0.2em]">Registrar</button>
                        <div id="mensajeGarita" class="text-center h-14 flex items-center justify-center font-black text-2xl uppercase italic mt-4"></div>
                    </div>
                </div>

                <div class="flex flex-col gap-6 w-full">
                    <h3 class="text-[11px] font-black tracking-[0.5em] text-slate-500 px-6 uppercase flex justify-between">
                        <span>Bitácora de Operaciones</span>
                        <span class="text-blue-500" id="countHistorial">0 Reg</span>
                    </h3>
                    <div id="historialGarita" class="scroll-bitacora"></div>
                </div>
            </div>

            <!-- PATIO -->
            <div id="patio" class="hidden">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                    <div class="lg:col-span-2 space-y-4">
                        <div class="glass p-5 rounded-2xl border-l-4 border-cyan-500 shadow-[0_0_15px_rgba(6,182,212,0.1)]">
                            <p class="text-[10px] font-black text-slate-500 uppercase mb-1 tracking-widest">Viajes Despachados</p>
                            <div id="kpiViajes" class="text-4xl font-black text-cyan-400 mt-1">0</div>
                        </div>
                        <div class="glass p-5 rounded-2xl border-l-4 border-blue-500">
                            <p class="text-[10px] font-black text-slate-500 uppercase mb-3 tracking-widest">En Patio</p>
                            <ul id="listaKpiPatio" class="text-xs font-bold space-y-1 text-slate-400"></ul>
                        </div>
                        <div class="glass p-5 rounded-2xl border-l-4 border-emerald-500">
                            <p class="text-[10px] font-black text-slate-500 uppercase mb-3 tracking-widest">En Rampa</p>
                            <ul id="listaKpiRampa" class="text-xs font-bold space-y-1 text-slate-400"></ul>
                        </div>
                        <div class="pt-2">
                            <p class="text-[10px] font-black text-slate-600 uppercase mb-2 px-1 tracking-widest">Solicitudes</p>
                            <div id="listaSolicitudesDespacho" class="space-y-2"></div>
                        </div>
                    </div>
                    <div class="lg:col-span-10 glass rounded-3xl overflow-hidden flex flex-col">
                        <div class="p-4 border-b border-slate-800 bg-slate-900/30 flex gap-4 items-center">
                            <div class="relative flex-1">
                                <span class="absolute left-4 top-2.5 text-slate-500 text-sm pointer-events-none">🔍</span>
                                <input id="filtroPatio" oninput="renderPatio()" class="w-full bg-black/40 border border-slate-700 rounded-xl p-2 pl-10 text-sm outline-none focus:border-blue-500 text-white placeholder-slate-600" placeholder="Filtrar por ID, Nombre o Tipo…">
                            </div>
                        </div>
                        <div class="scroll-container">
                            <table class="w-full text-left table-compact">
                                <thead><tr><th>Ubicación</th><th>ID</th><th>Conductor</th><th>Tipo</th><th>Tiempo</th><th>Estado</th><th style="text-align:right">Acción</th></tr></thead>
                                <tbody id="tablaPatioCuerpo"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- DESPACHO -->
            <div id="despacho" class="hidden flex flex-col gap-6">
                <div class="flex flex-wrap justify-between items-end px-4 gap-4 mb-2">
                    <h3 class="text-xs font-black text-slate-500 uppercase tracking-widest italic">Panel Maestro de Despacho</h3>
                </div>
                <div id="gridDespacho" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-6 gap-4"></div>
            </div>

            <!-- ADMIN -->
            <div id="admin" class="hidden max-w-7xl mx-auto glass p-10 rounded-[3rem] shadow-2xl">
                <h2 class="text-2xl font-black tracking-tighter uppercase italic text-blue-400 mb-6">Administración Central</h2>
                <div class="flex gap-4 mb-8 border-b border-slate-700 pb-4">
                    <button onclick="switchAdminTab('form')" id="btnTabForm" class="bg-blue-600 px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all">Gestión de Usuarios</button>
                    <button onclick="switchAdminTab('audit')" id="btnTabAudit" class="bg-slate-800 text-slate-400 px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-slate-700 transition-all">Auditoría de Ciclos</button>
                </div>

                <div id="adminFormSection">
                    <div class="flex justify-end mb-6">
                        <select id="filtroTipo" onchange="ajustarFormularioAdmin()" class="bg-blue-600 hover:bg-blue-500 p-4 rounded-2xl text-[10px] font-black tracking-widest transition-all cursor-pointer uppercase outline-none border-none shadow-xl shadow-blue-900/20">
                            <option value="GARITA">Nuevo: Operador Garita</option><option value="PATIO">Nuevo: Operador Patio</option><option value="DESPACHO">Nuevo: Operador Despacho</option><option value="CHOFER">Nuevo: Chofer Externo</option><option value="ADMIN">Nuevo: Administrador</option>
                        </select>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12 bg-slate-950/50 p-10 rounded-[2rem] border border-slate-800">
                        <div class="flex flex-col gap-2"><label class="text-[10px] font-black text-slate-600 ml-3 uppercase">Código / Ficha</label><input id="regCodigo" class="p-4 bg-slate-900 rounded-2xl border border-slate-800 outline-none focus:border-blue-500 font-bold" placeholder="EJ. 2024-01" onkeydown="if(event.key==='Enter') document.getElementById('regNombre').focus()"></div>
                        <div class="flex flex-col gap-2"><label class="text-[10px] font-black text-slate-600 ml-3 uppercase">Nombre de Usuario</label><input id="regNombre" class="p-4 bg-slate-900 rounded-2xl border border-slate-800 outline-none focus:border-blue-500 font-bold" placeholder="NOMBRE COMPLETO" onkeydown="if(event.key==='Enter') document.getElementById('regPassword').focus()"></div>
                        <div class="flex flex-col gap-2"><label class="text-[10px] font-black text-slate-600 ml-3 uppercase">Contraseña</label><input id="regPassword" class="p-4 bg-slate-900 rounded-2xl border border-slate-800 outline-none focus:border-blue-500 font-bold" placeholder="(Dejar blanco para crear después)" onkeydown="if(event.key==='Enter') { document.getElementById(document.getElementById('filtroTipo').value === 'CHOFER' ? 'regTelefono' : 'regPosicion').focus(); }"></div>
                        <div id="contPos" class="flex flex-col gap-2"><label class="text-[10px] font-black text-slate-600 ml-3 uppercase">Posición / Rango</label><input id="regPosicion" class="p-4 bg-slate-900 rounded-2xl border border-slate-800 outline-none focus:border-blue-500 font-bold" placeholder="PUESTO OPERATIVO" onkeydown="if(event.key==='Enter') crearUsuario()"></div>
                        <div id="contTel" class="hidden flex flex-col gap-2"><label class="text-[10px] font-black text-slate-600 ml-3 uppercase">Contacto</label><input id="regTelefono" class="p-4 bg-slate-900 rounded-2xl border border-slate-800 outline-none focus:border-blue-500 font-bold" placeholder="TELÉFONO" onkeydown="if(event.key==='Enter') document.getElementById('regCompania').focus()"></div>
                        <div id="contComp" class="hidden flex flex-col gap-2"><label class="text-[10px] font-black text-slate-600 ml-3 uppercase">Compañía</label><input id="regCompania" class="p-4 bg-slate-900 rounded-2xl border border-slate-800 outline-none focus:border-blue-500 font-bold" placeholder="EMPRESA" onkeydown="if(event.key==='Enter') document.getElementById('regTipoCamion').focus()"></div>
                        <div id="contTipoCam" class="hidden flex flex-col gap-2"><label class="text-[10px] font-black text-slate-600 ml-3 uppercase">Configuración de Camión</label>
                            <select id="regTipoCamion" class="p-4 bg-slate-900 rounded-2xl border border-slate-800 outline-none focus:border-blue-500 font-bold text-slate-400" onkeydown="if(event.key==='Enter') crearUsuario()">
                                <option value="CAMION_FRIO">CAMION FRIO ❄️</option>
                                <option value="CAMION_SECO">CAMION SECO</option>
                                <option value="DOLLY">DOLLY</option>
                                <option value="FURGON_REF">FURGON REF ❄️</option>
                                <option value="FURGON_SECO">FURGON SECO</option>
                                <option value="RIGIDO">RIGIDO</option>
                            </select>
                        </div>
                        <button onclick="crearUsuario()" class="lg:col-span-3 bg-blue-600 hover:bg-blue-500 p-6 rounded-2xl font-black text-sm tracking-[0.3em] transition-all shadow-2xl mt-6 uppercase">Vincular al Sistema</button>
                    </div>
                    <div class="overflow-x-auto"><table class="w-full"><thead class="text-slate-600 text-[11px] font-black uppercase tracking-[0.3em] border-b border-slate-800"><tr><th class="p-6 text-left">Ficha</th><th class="p-6 text-left">Usuario</th><th class="p-6 text-left">Detalles</th><th class="p-6 text-right">Control</th></tr></thead><tbody id="listaUsuarios" class="divide-y divide-slate-800/50"></tbody></table></div>
                </div>

                <div id="adminAuditSection" class="hidden overflow-x-auto">
                    <table class="w-full text-left table-compact">
                        <thead><tr><th>Fecha / Hora</th><th>ID de Ciclo</th><th>Ficha</th><th>Chofer</th><th>Módulo</th><th>Acción Registrada</th></tr></thead>
                        <tbody id="listaAuditoriaCuerpo"></tbody>
                    </table>
                </div>
            </div>

            <!-- CHOFER -->
            <div id="chofer" class="hidden max-w-md mx-auto glass p-14 rounded-[4rem] text-center shadow-2xl mt-10">
                <h2 id="infoChoferNombre" class="text-4xl font-black mb-3 text-amber-500 uppercase italic tracking-tighter"></h2>
                <p class="text-[10px] text-slate-600 tracking-[0.5em] mb-12 uppercase font-black">Monitoreo de Turno</p>
                <div id="infoChofer" class="bg-slate-950/90 p-10 rounded-[2.5rem] mb-10 text-3xl font-black border border-white/5 shadow-inner"></div>
                <div id="accionChofer"></div>
            </div>

        </div>
    </div>

    <!-- POPUPS Y MODALES -->
    <div id="modalScanner" class="hidden fixed inset-0 bg-black/95 z-[999] flex flex-col items-center justify-center p-4">
        <h3 class="text-white font-black text-2xl uppercase tracking-widest mb-6">Escáner Activo</h3>
        <div class="w-full max-w-sm bg-white rounded-3xl overflow-hidden shadow-[0_0_50px_rgba(16,185,129,0.3)]">
            <div id="reader" style="width: 100%;"></div>
        </div>
        <button onclick="detenerScanner()" class="mt-8 bg-red-600 hover:bg-red-500 text-white px-8 py-4 rounded-2xl font-black uppercase tracking-widest active:scale-95 transition-all">Cancelar y Cerrar</button>
    </div>

    <div id="driverAlert" class="hidden fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center z-50">
        <div class="bg-blue-600 p-10 rounded-[2.5rem] text-center max-w-sm w-full mx-4 shadow-[0_20px_60px_rgba(37,99,235,0.5)] border-2 border-white/20">
            <div class="text-5xl mb-4">🚚</div><p id="driverMsg" class="font-black text-xl uppercase mb-8 text-white leading-snug"></p><button onclick="document.getElementById('driverAlert').classList.add('hidden')" class="w-full bg-white text-blue-600 font-black py-4 rounded-2xl text-lg uppercase active:scale-95 transition-transform">Entendido</button>
        </div>
    </div>
    
    <div id="choferAlert" class="hidden fixed top-10 left-1/2 -translate-x-1/2 w-[92%] max-w-md bg-blue-600 p-8 rounded-[2.5rem] shadow-[0_20px_50px_rgba(37,99,235,0.5)] z-[100] border-4 border-white/20 backdrop-blur-xl">
        <div class="text-center">
            <div class="text-5xl mb-4">🚛</div><h4 class="font-black text-2xl uppercase mb-2">¡Carga Lista!</h4><p id="msgChofer" class="text-sm font-bold mb-8 text-blue-100 italic"></p><button onclick="choferAceptaSalida()" class="w-full bg-white text-blue-600 font-black py-5 rounded-2xl text-lg uppercase shadow-xl active:scale-95 transition-transform">Confirmar Salida y Liberar Rampa</button>
        </div>
    </div>

    <!-- Enlace a los scripts JS -->
    <script src="script.js"></script>
</body>
</html>
